---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import ScheduleView from "@/components/ScheduleView.astro";
import { getCenterDate, getDatesWithMatches, getMatches } from "@/lib/data";

const matches = getMatches();
const selectedDate = getCenterDate(matches);
const matchDates = getDatesWithMatches(matches);
const basePath = (import.meta.env.BASE_URL || "/").replace(/\/$/, "");
---

<BaseLayout active="home">
  <SiteHeader />
  <ScheduleView selectedDate={selectedDate} />

  <script define:vars={{ matchDates, basePath }}>
    const dates = Array.isArray(matchDates) ? matchDates : [];

    function getBeijingParts() {
      const parts = new Intl.DateTimeFormat("en-CA", {
        timeZone: "Asia/Shanghai",
        year: "numeric",
        month: "2-digit",
        day: "2-digit",
        hour: "2-digit",
        minute: "2-digit",
        hour12: false,
      }).formatToParts(new Date());
      const values = Object.fromEntries(parts.map((part) => [part.type, part.value]));
      const hour = Number(values.hour === "24" ? "0" : values.hour);
      return {
        date: `${values.year}-${values.month}-${values.day}`,
        hour: Number.isFinite(hour) ? hour : 0,
      };
    }

    function pickTargetDate() {
      if (!dates.length) return "";
      const now = getBeijingParts();
      const todayIndex = dates.indexOf(now.date);
      if (todayIndex >= 0) {
        if (now.hour >= 13) return dates[todayIndex + 1] || dates[todayIndex];
        return dates[todayIndex];
      }
      return dates.find((date) => date > now.date) || dates[dates.length - 1];
    }

    const targetDate = pickTargetDate();
    if (targetDate) {
      const base = basePath || "";
      window.location.replace(`${base}/date/${targetDate}/`);
    }
  </script>
</BaseLayout>
