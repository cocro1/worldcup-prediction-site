---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import { articleHref, getReviewedDeductions } from "@/lib/data";

const reports = getReviewedDeductions();
---

<BaseLayout active="deductions" title="推演 - 2026 世界杯预测">
  <SiteHeader subtitle="推演文章" />
  <section class="list-section">
    <h2>推演</h2>
    <div class="article-list">
      {reports.length === 0 && <div class="empty-state">暂无已校对推演文章</div>}
      {reports.map((item) => (
        <a class="article-row" href={articleHref(item.article_path)}>
          <span>{item.deduction_date}</span>
          <strong>{item.title}</strong>
          <em>{item.matches?.length || 0} 场比赛</em>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
