---
import BaseLayout from "@/layouts/BaseLayout.astro";
import SiteHeader from "@/components/SiteHeader.astro";
import ScheduleView from "@/components/ScheduleView.astro";
import { getDatesWithMatches, getMatches } from "@/lib/data";

export function getStaticPaths() {
  return getDatesWithMatches(getMatches()).map((date) => ({
    params: { date },
    props: { selectedDate: date },
  }));
}

const { selectedDate } = Astro.props as { selectedDate: string };
---

<BaseLayout active="home">
  <SiteHeader />
  <ScheduleView selectedDate={selectedDate} />
</BaseLayout>
