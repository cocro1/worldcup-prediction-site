---
import {
  confidenceLabel,
  formatScore,
  matchStageLabel,
} from "@/lib/data";
import type { Match, Prediction, DeductionMatch, Result } from "@/lib/types";

const { match, prediction, deduction, result } = Astro.props as {
  match: Match;
  prediction?: Prediction;
  deduction?: DeductionMatch;
  result?: Result;
};

const predictionReady = Boolean(prediction);
const deductionReady = Boolean(deduction);
const handicapReady = result?.handicap;
const hasActualScore = result && Number.isInteger(result.home_score_90) && Number.isInteger(result.away_score_90);
const mainScore = predictionReady
  ? formatScore(prediction?.prediction_score)
  : "待生成";
const backupScore = predictionReady ? formatScore(prediction?.backup_score) : "";
const home = match.home_team.display_name_zh;
const away = match.away_team.display_name_zh;
const deductionScores = deductionReady
  ? deduction?.deduction_scores?.map(formatScore).join(" / ")
  : "待生成";
const over25 = deductionReady && typeof deduction?.over_2_5_probability === "number"
  ? `${(deduction.over_2_5_probability * 100).toFixed(1)}%`
  : "待生成";
---

<article class="match-card">
  <div class="match-meta">
    <span>{matchStageLabel(match)}</span>
    <span>预测比分</span>
    <span>开赛 {match.kickoff_beijing_time} 北京</span>
  </div>
  <div class="score-board">
    <div class="team">
      <div class="flag-bubble">{match.home_team.is_placeholder ? "?" : <img src={"https://flagcdn.com/24x18/" + match.home_team.flag_code + ".png"} alt={match.home_team.flag_code} class="flag-img" />}</div>
      <strong>{home}</strong>
    </div>
    <div class="score-block">
      <div class:list={["main-score", !predictionReady && "pending"]}>{mainScore}</div>
      {predictionReady && <div class="backup-score">{backupScore}</div>}
    </div>
    <div class="team">
      <div class="flag-bubble">{match.away_team.is_placeholder ? "?" : <img src={"https://flagcdn.com/24x18/" + match.away_team.flag_code + ".png"} alt={match.away_team.flag_code} class="flag-img" />}</div>
      <strong>{away}</strong>
    </div>
  </div>
  <div class="status-row">
    <span class:list={["confidence", !predictionReady && "pending"]}>
      {predictionReady ? confidenceLabel(prediction?.confidence, prediction?.confidence_zh) : "待生成"}
    </span>
    {handicapReady && <span class="handicap">{result?.handicap}</span>}
    <span class="match-state">{hasActualScore ? `实际 ${result.home_score_90} : ${result.away_score_90}` : "未开赛"}</span>
  </div>
  <div class="detail-grid">
    <div class="mini-panel">
      <span>推演比分</span>
      <strong>{deductionScores}</strong>
    </div>
    <div class="mini-panel">
      <span>&gt;2.5 球概率</span>
      <strong>{over25}</strong>
    </div>
  </div>
</article>
